# Copy this file to .env and run scripts/bootstrap.sh to populate interactively.
# Vars without "Optional" in their comment are required.

# === <Section name, e.g. Service> ===

# Description of what this var is for and where to find / generate it.
# Example: "From <provider>'s admin console, settings page, copy the secret."
VAR_NAME=

# === <Another section, e.g. Public URLs> ===

# Description.
# Example: "Public HTTPS URL the service responds on. Production: https://example.com"
ANOTHER_VAR=

# === <Storage / DB> ===

# Path to local storage, relative to repo root.
DB_PATH=data/app.db

# === Observability ===

# Optional: Sentry DSN for error reporting.
SENTRY_DSN=

# Log level: DEBUG, INFO, WARNING, ERROR. Default INFO.
LOG_LEVEL=INFO

# === Behavior toggles ===

# Set "true" in development to log payloads instead of sending to external systems.
DEV_MODE=false
