# Copy this file to .env and run scripts/bootstrap.sh to populate interactively.
# Each var carries explicit metadata via `# @directive: value` lines preceding
# its declaration. Recognized directives include @description, @required,
# @default, @validator, @sensitive. Full directive vocabulary: docs/spec.md B-020.
# Free-text comments are still allowed for human context — bootstrap.sh shows
# them in prompts but doesn't parse them as metadata.

# === <Section name, e.g. Service> ===

# Example placeholder var — rename to your project's actual variable.
# @description: <what this var is for and where to find / generate it>
# @required
VAR_NAME=

# === <Another section, e.g. Public URLs> ===

# @description: Public HTTPS URL the service responds on (e.g. https://api.example.com)
# @required
# @validator: ^https?://.+$
ANOTHER_VAR=

# === Storage / DB ===

# @description: Path to local SQLite database, relative to repo root
# @required
# @default: data/app.db
DB_PATH=data/app.db

# === Observability ===

# @description: Sentry DSN for error reporting
# @optional
# @sensitive
SENTRY_DSN=

# @description: Log verbosity
# @required
# @default: INFO
# @validator: ^(DEBUG|INFO|WARNING|ERROR)$
LOG_LEVEL=INFO

# === Behavior toggles ===

# @description: Set true in development to log payloads instead of sending to external systems
# @required
# @default: false
# @validator: ^(true|false)$
DEV_MODE=false
